# --- Alpaca API ---
# API key/secret for a paper trading account. Used for historical OHLCV
# ingestion and pulling the market calendar.
ALPACA_API_KEY=
ALPACA_API_SECRET=

# --- Snowflake ---
# Account identifier (e.g. asdfg-hjkl), not a full URL.
SNOWFLAKE_ACCOUNT=
# Service user this connection authenticates as (e.g. loader_svc,
# transformer_svc) — determines which role's permissions apply.
SNOWFLAKE_USER=
SNOWFLAKE_DATABASE=
SNOWFLAKE_WAREHOUSE=
# Path to the private key (.p8) for this user, generated via openssl.
# See README "Getting started" for key generation steps.
SNOWFLAKE_PRIVATE_KEY_PATH=~/.snowflake/<service>_key.p8
# Only needed if the key was generated with a passphrase (-nocrypt skips this).
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=

# --- Airflow (metadata store, not the trading warehouse) ---
# Airflow's own internal Postgres metadata DB (DAG history, task state,
# users) - provisioned by docker-compose.yml's `postgres` service and
# persisted in a named volume. These three values configure that service
# AND must match what's embedded in AIRFLOW_META_CONN below.
AIRFLOW_META_POSTGRES_USER=airflow
AIRFLOW_META_POSTGRES_PASSWORD=
AIRFLOW_META_POSTGRES_DB=airflow_meta
# Connection string Airflow itself uses. Host is `postgres` - the Compose
# service name above, resolvable on the trading-net network - not
# localhost or an external host.
AIRFLOW_META_CONN=postgresql+psycopg2://airflow:<same password as above>@postgres:5432/airflow_meta
# Flask session/CSRF signing key for the Airflow webserver UI. Any random
# string; generate with `openssl rand -hex 32`.
AIRFLOW_SECRET_KEY=

# --- Strategy config ---
# Starting simulated cash per (strategy_used, ticker) pair in backtesting.
STARTING_CASH=10000